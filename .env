# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=5000
NODE_ENV=development
BASE_URL=http://localhost:5000

# ============================================
# DATABASE - PostgreSQL
# ============================================
# Développement local
DATABASE_URL="postgresql://postgres:root@localhost:5432/voaray_db"

# Pour les tests
DATABASE_URL_TEST="postgresql://postgres:root@localhost:5432/voaray_db_test"

# Pool de connexions
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_TIMEOUT=20000

# ============================================
# REDIS (Cache & Rate Limiting)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# SECURITY
# ============================================
SECRET_KEY=5f7d8e9f0a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d
JWT_SECRET=8e9f0a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f
JWT_EXPIRES_IN=7d

# CORS - Développement
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:5000
CORS_CREDENTIALS=true

# ============================================
# SHOPIFY CONFIGURATION
# ============================================
SHOPIFY_API_KEY=your-shopify-api-key
SHOPIFY_API_SECRET=your-shopify-api-secret
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_STORE_URL=your-store.myshopify.com
SHOPIFY_API_VERSION=2024-01

# ============================================
# MVOLA API (Mobile Money Madagascar)
# ============================================
MVOLA_API_URL=https://api.mvola.mg
MVOLA_API_VERSION=v1.0
MVOLA_CLIENT_ID=your-mvola-client-id
MVOLA_CLIENT_SECRET=your-mvola-client-secret
MVOLA_MERCHANT_ID=your-merchant-id
MVOLA_CALLBACK_URL=http://localhost:5000/api/webhooks/mobile-money

# ============================================
# ORANGE MONEY API
# ============================================
ORANGE_API_URL=https://api.orange.mg
ORANGE_API_VERSION=v1
ORANGE_CLIENT_ID=your-orange-client-id
ORANGE_CLIENT_SECRET=your-orange-client-secret
ORANGE_MERCHANT_ID=your-merchant-id
ORANGE_CALLBACK_URL=http://localhost:5000/api/webhooks/orange-money

# ============================================
# AIRTEL MONEY API
# ============================================
AIRTEL_API_URL=https://api.airtel.mg
AIRTEL_API_VERSION=v1
AIRTEL_CLIENT_ID=your-airtel-client-id
AIRTEL_CLIENT_SECRET=your-airtel-client-secret
AIRTEL_MERCHANT_ID=your-merchant-id
AIRTEL_CALLBACK_URL=http://localhost:5000/api/webhooks/airtel-money

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=debug
LOG_FILE=logs/app.log
LOG_ERROR_FILE=logs/error.log

# ============================================
# EMAIL (SendGrid) - Optionnel
# ============================================
SENDGRID_API_KEY=your-sendgrid-api-key
FROM_EMAIL=noreply@voaray.com
FROM_NAME=Voaray Payment

# ============================================
# SMS (Twilio) - Optionnel
# ============================================
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+261XXXXXXXXX

# ============================================
# PAYMENT CONFIGURATION
# ============================================
PAYMENT_TIMEOUT=300
PAYMENT_FEE_PERCENTAGE=1.5
PAYMENT_FEE_FIXED=500
MIN_AMOUNT=100
MAX_AMOUNT=10000000

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
RATE_LIMIT_PAYMENT_MAX=10

# ============================================
# WEBHOOK RETRY
# ============================================
WEBHOOK_RETRY_MAX_ATTEMPTS=3
WEBHOOK_RETRY_DELAY=1000
WEBHOOK_TIMEOUT=10000

# ===========================================
# Email (SMTP)
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@voaray.com