// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  CANCELLED
  REFUNDED
  EXPIRED
}

enum PaymentMethod {
  MVOLA
  ORANGE
  AIRTEL
}

enum TransactionType {
  PAYMENT
  REFUND
  REVERSAL
}

enum WebhookEvent {
  PAYMENT_CREATED
  PAYMENT_CONFIRMED
  PAYMENT_FAILED
  PAYMENT_EXPIRED
  PAYMENT_REFUNDED
  SHOPIFY_ORDER_CREATED
  SHOPIFY_ORDER_PAID
  SHOPIFY_ORDER_CANCELLED
}

enum PartnerStatus {
  ACTIVE
  MAINTENANCE
  INACTIVE
}

// ============================================
// MODELS
// ============================================

model Payment {
  id            String        @id @default(uuid())
  orderId       String        @unique @map("order_id")
  amount        Float
  phone         String
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  transactionId String?       @unique @map("transaction_id")
  reference     String?       @unique
  providerRef   String?       @map("provider_ref")
  metadata      Json?
  errorMessage  String?       @map("error_message")
  retryCount    Int           @default(0)
  fee           Float?
  netAmount     Float?        @map("net_amount")
  expiresAt     DateTime?     @map("expires_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  completedAt   DateTime?     @map("completed_at")

  transactions Transaction[]
  webhookLogs  WebhookLog[]
  refunds      Refund[]

  @@index([orderId])
  @@index([status])
  @@index([method])
  @@index([createdAt])
  @@index([reference])
  @@map("payments")
}

model Transaction {
  id           String          @id @default(uuid())
  paymentId    String          @map("payment_id")
  type         TransactionType @default(PAYMENT)
  provider     String
  providerRef  String          @map("provider_ref")
  amount       Float
  fee          Float
  netAmount    Float           @map("net_amount")
  currency     String          @default("MGA")
  status       String
  metadata     Json?
  requestData  Json?           @map("request_data")
  responseData Json?           @map("response_data")
  createdAt    DateTime        @default(now()) @map("created_at")

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@index([providerRef])
  @@index([provider])
  @@index([createdAt])
  @@map("transactions")
}

model WebhookLog {
  id          String       @id @default(uuid())
  paymentId   String?      @map("payment_id")
  event       WebhookEvent
  source      String
  payload     Json
  response    Json?
  statusCode  Int          @map("status_code")
  ipAddress   String?      @map("ip_address")
  userAgent   String?      @map("user_agent")
  error       String?
  processedAt DateTime     @default(now()) @map("processed_at")
  createdAt   DateTime     @default(now()) @map("created_at")

  payment Payment? @relation(fields: [paymentId], references: [id])

  @@index([paymentId])
  @@index([event])
  @@index([source])
  @@index([createdAt])
  @@map("webhook_logs")
}

model Refund {
  id            String    @id @default(uuid())
  paymentId     String    @map("payment_id")
  transactionId String    @map("transaction_id")
  amount        Float
  reason        String?
  status        String    @default("PENDING")
  providerRef   String?   @map("provider_ref")
  metadata      Json?
  processedAt   DateTime? @map("processed_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@index([status])
  @@map("refunds")
}

model ApiKey {
  id           String    @id @default(uuid())
  name         String
  key          String    @unique
  secret       String
  merchantId   String    @map("merchant_id")
  merchantName String    @map("merchant_name")
  email        String?
  active       Boolean   @default(true)
  permissions  Json      @default("[]")
  rateLimit    Int       @default(100)
  lastUsedAt   DateTime? @map("last_used_at")
  expiresAt    DateTime  @map("expires_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([key])
  @@index([merchantId])
  @@index([active])
  @@map("api_keys")
}

model PaymentSession {
  id        String   @id @default(uuid())
  paymentId String?  @map("payment_id")
  sessionId String   @unique @map("session_id")
  data      Json
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([sessionId])
  @@index([expiresAt])
  @@map("payment_sessions")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  action    String
  entity    String
  entityId  String?  @map("entity_id")
  oldData   Json?    @map("old_data")
  newData   Json?    @map("new_data")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([entity])
  @@index([entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Merchant {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  phone         String?
  companyName   String   @map("company_name")
  taxId         String?  @map("tax_id")
  address       Json?
  settings      Json?
  webhookUrl    String?  @map("webhook_url")
  webhookSecret String?  @map("webhook_secret")
  active        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  apiKeys ApiKey[]

  @@index([email])
  @@index([active])
  @@map("merchants")
}

model Notification {
  id         String    @id @default(uuid())
  paymentId  String?   @map("payment_id")
  type       String
  recipient  String
  subject    String?
  content    String
  status     String    @default("PENDING")
  provider   String?
  providerId String?   @map("provider_id")
  error      String?
  sentAt     DateTime? @map("sent_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([paymentId])
  @@index([status])
  @@index([createdAt])
  @@map("notifications")
}

// ============================================
// NOUVEAU MODÈLE: PARTNER CONFIG
// ============================================

model PartnerConfig {
  id            String        @id @default(uuid())
  name          String        @unique
  apiUrl        String        @map("api_url")
  clientId      String        @map("client_id")
  clientSecret  String        @map("client_secret")
  merchantId    String        @map("merchant_id")
  webhookSecret String?       @map("webhook_secret")
  feePercentage Float         @map("fee_percentage")
  feeFixed      Float         @map("fee_fixed")
  status        PartnerStatus @default(ACTIVE)
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  @@index([name])
  @@index([status])
  @@map("partner_configs")
}
